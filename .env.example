# Copy this file to `.env` (gitignored) for local development.
# main.py auto-loads `.env` on startup, so `uvicorn main:app --reload` picks these
# up with no `export` needed. In production, set these as real env/secret variables
# instead (they take precedence over any .env).

# Your OpenRouter key. Absent -> the app runs on offline rule-based coaching.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Print each OpenRouter request+response to the terminal (stderr). Handy under
# `uvicorn --reload`. Set to a file path to append there instead; remove to disable.
LLM_LOG_FILE=stderr

# --- Optional overrides (sensible defaults if omitted) ---
# LLM_MODEL=google/gemini-2.5-flash-lite   # the default (A/B winner); any non-reasoning
#                                          # model on openrouter.ai/models. Avoid ':free'
#                                          # ids - they rate-limit (429) and fall back to rules.
# LLM_COACH=1                        # force the LLM path on/off (1/0); default: on iff a key is set
# LLM_MAX_CALLS_PER_HOUR=60          # abuse cap for a public endpoint on your key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MAX_CONCURRENT_RENDERS=2           # video renders at once; extra jobs wait as "Queued"
# MAX_UPLOAD_MB=100                  # upload size cap; buffered in RAM per upload, mind memory
# CORS_ORIGINS=http://localhost:3000 # comma-separated frontend origins allowed to call the API
# POSE_BACKEND=mediapipe             # or 'yolo' (needs requirements-dev.txt)
# POSE_MODEL=models/pose_landmarker_lite.task
