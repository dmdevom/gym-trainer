# ---- Python bytecode ----
__pycache__/
*.pyc

# ---- Virtualenvs ----
.venv/
venv/

# ---- Local secrets (never commit real keys) ----
# .env holds OPENROUTER_API_KEY etc. for local dev and is auto-loaded on start;
# the committable template is .env.example.
.env
.env.local

# ---- Run / debug artifacts ----
out/
probe_out/
angle_series.json
angle_series.png

# ---- Large model weights (fetched at build time, never committed) ----
models/pose_landmarker_lite.task
models/pose_landmarker_heavy.task
yolov8n-pose.pt

# ---- Local test media (photos + clips; excluded from every deploy already) ----
# Stops NEW media landing in the repo. Files already tracked under data/ stay
# tracked; to slim the repo run `git rm -r --cached data/` (keeps local copies).
data/

# ---- Local planning notes (kept untracked; see commit "Untrack planning notes") ----
raw-docs/
